# =============================================================================
# AKHILA FUNNEL — .gitignore
# Keep the working directory pristine. Anything that can be regenerated by a
# build/install command, anything machine-specific, anything containing secrets,
# and any local scratch work must NEVER hit git.
# =============================================================================

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/cache
.yarn/install-state.gz

# ── Next.js build output + caches ────────────────────────────────────────────
.next/
out/
build/
dist/
.swc/
.turbo/

# ── Test / preview artifacts ─────────────────────────────────────────────────
snapshots/
playwright-report/
test-results/
.playwright/
coverage/

# ── Environment files (NEVER commit secrets) ─────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Logs / debug ────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/

# ── Editor / OS scratch ─────────────────────────────────────────────────────
.vscode/
.idea/
.cursor/
.history/
.zed/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Local scratch files (anything starting with _ or .scratch) ──────────────
_scratch/
.scratch/
*.local.md
TODO.local.*

# ── Misc ────────────────────────────────────────────────────────────────────
*.pem
*.cer
*.pfx
*.key
.cache/
tmp/
temp/
