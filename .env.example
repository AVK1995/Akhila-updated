# =============================================================================
# AKHILA PCOS FUNNEL — ENVIRONMENT VARIABLES
# Copy this file to `.env.local` and fill in real values. Never commit secrets.
# =============================================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://akhila.example.com
NEXT_PUBLIC_SITE_NAME="Dr. Aditya & Akhila — PCOS Metabolic Programme"

# --- Razorpay (server-side, never expose) ---
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# --- Razorpay public key (exposed to browser, this is OK) ---
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# --- Assessment fee in INR ---
# SINGLE SOURCE OF TRUTH for the price tag everywhere on the site.
# Drives: hero pill, all CTAs, pricing card, FAQ refund line, sticky bar,
# marquee strip, meta description, JSON-LD schema, OG image, Razorpay order.
# Change this and restart the dev server (or rebuild prod) — Next.js inlines
# NEXT_PUBLIC_* vars at build time.
NEXT_PUBLIC_ASSESSMENT_FEE_INR=97

# Legacy/optional server-only fallback (kept for back-compat — prefer the
# NEXT_PUBLIC_ one above; server reads NEXT_PUBLIC first, then this).
# ASSESSMENT_FEE_INR=497

# --- Pabbly Webhooks ---
# Fires immediately when payment is verified successfully
PABBLY_PURCHASE_WEBHOOK_URL=https://connect.pabbly.com/workflow/sendwebhookdata/IjU3...
# Fires after ABANDONED_CART_DELAY_MINUTES if user filled checkout form but never paid
PABBLY_ABANDONED_WEBHOOK_URL=https://connect.pabbly.com/workflow/sendwebhookdata/IjU3...

# --- Abandoned cart delay (minutes). Default 240 = 4 hours ---
ABANDONED_CART_DELAY_MINUTES=240

# --- Optional: Calendly link for the Book-a-Call page embed ---
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/akhila-pcos/assessment-call
